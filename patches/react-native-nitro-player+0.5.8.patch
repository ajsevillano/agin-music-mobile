+    /**
+     * Promote this service to a foreground service of type MEDIA_PLAYBACK. Without this,
+     * Android 14+ treats the audio process as a background activity and may restrict its
+     * network/CPU at any moment after the screen turns off, which causes random playback cuts.
+     */
+    fun promoteToForeground(notification: Notification) {
+        try {
+            val type =
+                if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.Q) {
+                    ServiceInfo.FOREGROUND_SERVICE_TYPE_MEDIA_PLAYBACK
+                } else {
+                    0
+                }
+            ServiceCompat.startForeground(this, NOTIFICATION_ID, notification, type)
+            if (!isInForeground) {
+                isInForeground = true
+                NitroPlayerLogger.log("MediaBrowserService", "🚀 Service promoted to foreground (type=mediaPlayback)")
+            }
+        } catch (e: Exception) {
+            NitroPlayerLogger.log("MediaBrowserService", "❌ Failed to promote service to foreground: ${e.message}")
+        }
+    }
