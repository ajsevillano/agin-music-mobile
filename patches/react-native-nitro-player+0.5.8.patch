+  func reorderPlaylist(playlistId: String, oldIndex: Int, newIndex: Int) {
+    DispatchQueue.main.async { [weak self] in
+      guard let self = self else { return }
+      if self.currentPlaylistId == playlistId {
+        let playlist = self.playlistManager.getPlaylist(playlistId: playlistId)
+        if let playlist = playlist {
+          self.currentTracks = playlist.tracks
+
+          // Update currentTrackIndex if necessary
+          if self.currentTrackIndex == oldIndex {
+            self.currentTrackIndex = newIndex
+          } else if self.currentTrackIndex > oldIndex && self.currentTrackIndex <= newIndex {
+            self.currentTrackIndex -= 1
+          } else if self.currentTrackIndex >= newIndex && self.currentTrackIndex < oldIndex {
+            self.currentTrackIndex += 1
+          }
+
+          self.rebuildAVQueueFromCurrentPosition()
+        }
+      }
+    }
+  }
