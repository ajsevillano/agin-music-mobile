+     * so the lock-screen control survives a pause without the process retaining foreground
+     * privileges (and thus battery cost) it no longer needs.
+     */
+    fun demoteFromForeground(removeNotification: Boolean) {
+        if (!isInForeground) return
+        try {
+            val flag = if (removeNotification) ServiceCompat.STOP_FOREGROUND_REMOVE else ServiceCompat.STOP_FOREGROUND_DETACH
+            ServiceCompat.stopForeground(this, flag)
+            isInForeground = false
+            NitroPlayerLogger.log("MediaBrowserService", "🛑 Service demoted from foreground")
